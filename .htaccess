# Padang Records · cache strategy
# HTML/JS/JSON: revalidate every load (max-age small + must-revalidate)
# Images/fonts: cache long-term (immutable assets)

<IfModule mod_headers.c>
  <FilesMatch "\.(html|js|json|css)$">
    Header set Cache-Control "public, max-age=300, must-revalidate"
  </FilesMatch>
  <FilesMatch "\.(svg|png|jpg|jpeg|gif|webp|ico|woff|woff2|ttf|otf)$">
    Header set Cache-Control "public, max-age=2592000, immutable"
  </FilesMatch>
  # Security niceties
  Header set X-Content-Type-Options "nosniff"
  Header set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>

# Force UTF-8
AddDefaultCharset UTF-8

# Gzip compress text-based files
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css application/javascript application/json image/svg+xml
</IfModule>
